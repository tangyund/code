<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qidianit.mes.sys.mapper.SupplierMapper">
    <insert useGeneratedKeys="true" id="saveSupplier" keyProperty="id" keyColumn="id" >
        INSERT INTO supplier(code,name,address,contact_person,phone,fax,email,description,status)
        VALUES(#{code},#{name},#{address},#{contactPerson},#{phone},#{fax},#{email},#{description},#{status})
    </insert>
    <update id="updateById" parameterType="com.qidianit.mes.pojo.Supplier">
        update supplier  set update_time = now()
        <if test="code != null and code != ''">
            ,code = #{code}
        </if>
        <if test="name != null and name != ''">
            ,name = #{name}
        </if>
        <if test="address != null and address != ''">
            ,address = #{address}
        </if>
        <if test="contactPerson != null and contactPerson != ''">
            ,contact_person = #{contactPerson}
        </if>
        <if test="phone != null and phone != ''">
            ,phone = #{phone}
        </if>
        <if test="fax != null and fax != ''">
            ,fax = #{fax}
        </if>
        <if test="email != null and email != ''">
            ,email = #{email}
        </if>
        <if test="description != null and description != ''">
            ,description = #{description}
        </if>
        <if test="status != null">
            ,status = #{status}
        </if>
        where id = #{id}
    </update>

    <update id="deleteById" parameterType="long">
        update supplier set delete_flag = 1 where id = #{id}
    </update>

    <update id="batchDelete">
        update supplier set delete_flag =1
        where id in
        <foreach collection="ids" item="id" open="(" close=")" separator=",">
            #{id}
        </foreach>

    </update>


    <select id="selectList" resultType="com.qidianit.mes.pojo.Supplier">
        SELECT * FROM supplier WHERE delete_flag != 1
        <if test="code != null and code != ''">
            AND code = #{code}
        </if>
        <if test="name != null and name != ''">
            AND name = #{name}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
    </select>
    <select id="selectByCode" resultType="com.qidianit.mes.pojo.Supplier">
        select * from supplier WHERE delete_flag != 1 AND code = #{code}
    </select>
</mapper>
