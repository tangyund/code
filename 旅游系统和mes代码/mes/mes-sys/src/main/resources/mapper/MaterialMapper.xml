<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.qidianit.mes.sys.mapper.MaterialMapper">

    <select id="selectList" parameterType="com.qidianit.mes.pojo.Material">
        select * from material where delete_flag=0
        <if test="code !=null and code!=''">
            and code=#{code}
        </if>
        <if test="name !=null and name!=''">
            and name like concat('%',#{name},'%')
        </if>
        <if test="status !=null ">
            and status=#{status}
        </if>

    </select>
    <select id="selectByCode" resultType="com.qidianit.mes.pojo.Material">
        select * from material where delete_flag=0 and material.code=#{code}
    </select>


</mapper>
