# API Key 优先从 feima-cloud/.../feima-fasting/ai-keys.env 加载（与 Java 服务一致）
# 如需本地覆盖，可在此配置：

# 阿里云 DashScope（通义千问）
DASHSCOPE_API_KEY=sk-xxx

# 火山引擎豆包（餐品识别视觉模型，优先使用）
# 获取方式：https://www.volcengine.com/docs/82379/1399008
ARK_API_KEY=xxx
# 可选，默认已填
# ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# DOUBAO_VISION_MODEL=doubao-seed-1-8-251228

# 百度 AI 餐品识别（备用）
BAIDU_API_KEY=xxx
BAIDU_SECRET_KEY=xxx

# Java API（feima-cloud 网关地址，供 question/answer/recipe 仓储调用）
JAVA_API_BASE_URL=http://127.0.0.1:8080
JAVA_API_TIMEOUT=30

# 数据库（与 Java 共用 MySQL，当前仓储已改为调用 Java API）
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=xxx
MYSQL_DATABASE=feima_fasting
